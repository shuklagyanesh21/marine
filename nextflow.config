/*
 * Nextflow configuration.
 *
 * Parameters are loaded from config/config.yaml so the pipeline and the Python/CLI
 * code share a single source of truth (see AGENTS.md: no hardcoded params).
 */

import org.yaml.snakeyaml.Yaml

def cfg = new Yaml().load(new File("${projectDir}/config/config.yaml").text)

params {
    // Paths
    data_raw        = cfg.paths.data_raw
    data_external   = cfg.paths.data_external
    data_interim    = cfg.paths.data_interim
    data_processed  = cfg.paths.data_processed
    results         = cfg.paths.results
    manifest        = cfg.paths.manifest

    // QC thresholds
    min_completeness  = cfg.qc.min_completeness
    max_contamination = cfg.qc.max_contamination

    // Dereplication / ORF
    ani_threshold      = cfg.dereplication.ani_threshold
    min_protein_length = cfg.orf.min_protein_length
    genetic_code       = cfg.orf.genetic_code

    // SmORFinder
    smorfinder_input_tsv         = cfg.smorfinder.input_tsv
    smorfinder_normalized_tsv    = cfg.smorfinder.normalized_tsv
    smorfinder_input_status_tsv  = cfg.smorfinder.input_status_tsv
    smorfinder_pending_tsv       = cfg.smorfinder.pending_tsv
    smorfinder_preflight_stamp   = cfg.smorfinder.preflight_stamp
    smorfinder_out_dir           = cfg.smorfinder.out_dir
    smorfinder_processed_manifest = cfg.smorfinder.processed_manifest
    smorfinder_env_yaml          = cfg.smorfinder.env_yaml
    smorfinder_conda_prefix      = cfg.smorfinder.conda_prefix
    smorfinder_assets_manifest   = cfg.smorfinder.assets_manifest
    smorfinder_cleanup_tmp       = cfg.smorfinder.cleanup_tmp
    smorfinder_retry_count       = cfg.smorfinder.retry_count
    smorfinder_retry_memory_factor = cfg.smorfinder.retry_memory_factor
    smorfinder_max_parallel_tasks = cfg.smorfinder.max_parallel_tasks
    smorfinder_single_cpus       = cfg.smorfinder.single.cpus
    smorfinder_single_memory_gb  = cfg.smorfinder.single.memory_gb
    smorfinder_single_time       = cfg.smorfinder.single.time
    smorfinder_meta_cpus         = cfg.smorfinder.meta.cpus
    smorfinder_meta_memory_gb    = cfg.smorfinder.meta.memory_gb
    smorfinder_meta_time         = cfg.smorfinder.meta.time
    smorfinder_dsn1_indiv        = cfg.smorfinder.cutoffs.dsn1_indiv
    smorfinder_dsn2_indiv        = cfg.smorfinder.cutoffs.dsn2_indiv
    smorfinder_phmm_indiv        = cfg.smorfinder.cutoffs.phmm_indiv
    smorfinder_dsn1_overlap      = cfg.smorfinder.cutoffs.dsn1_overlap
    smorfinder_dsn2_overlap      = cfg.smorfinder.cutoffs.dsn2_overlap
    smorfinder_phmm_overlap      = cfg.smorfinder.cutoffs.phmm_overlap
}

// Default resource limits (placeholders; refine per-process later)
process {
    cpus   = cfg.resources.max_cpus
    memory = "${cfg.resources.max_memory_gb} GB"
}

profiles {
    conda {
        conda.enabled = true
    }
    slurm {
        conda.enabled = true
        process.executor = 'slurm'
        executor.queueSize = cfg.smorfinder.max_parallel_tasks
    }
    standard {
        conda.enabled = true
    }
}

// Keep run reports out of git (see .gitignore)
trace.enabled    = true
trace.file       = "logs/nextflow-trace.txt"
trace.overwrite  = true
report.enabled   = true
report.file      = "logs/nextflow-report.html"
report.overwrite = true
timeline.enabled = true
timeline.file    = "logs/nextflow-timeline.html"
timeline.overwrite = true
