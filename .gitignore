# Data, results, models, logs - regenerable from code + configs (see AGENTS.md).
# Track the genome manifest TSV (under data/processed), not the data itself.
# NB: a directory ignored wholesale ("data/") can't have children re-included,
# so we ignore data/ contents but re-include the path down to the manifest.
data/*
!data/.gitkeep
!data/processed/
data/processed/*
!data/processed/genome_manifest.tsv
results/
models/
logs/

# Python / uv
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/
**/__pycache__/

# Nextflow
work/
.nextflow/
.nextflow.log*

# OS / editor
.DS_Store

#docs
docs/*.pptx
docs/research_papers/